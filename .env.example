# Template for .env.local — Infisical bootstrap credentials.
#
# Copy this file to .env.local and fill in the real values:
#
#   cp .env.example .env.local
#
# .env.local is gitignored (.env.* in .gitignore); .env.example is the only
# .env file that is committed (see the `!.env.example` allow-rule). NEVER put
# real secrets in this file.
#
# These two creds get you INTO the Infisical vault; every app secret
# (ATTIO_API_KEY, CALCOM_API_KEY, SLACK_BOT_TOKEN, ...) lives in Infisical
# itself, not here. Load into your shell once per session with:
#
#   set -a && source .env.local && set +a
#
# then run e.g.:
#
#   infisical secrets --projectId "$INFISICAL_PROJECT_ID" --token "$INFISICAL_TOKEN" --env=dev

# Service token or machine-identity access token for the team's Infisical project.
# Get it from the Infisical UI (Project → Access Control → service tokens / identities),
# or from a teammate / the parent `ai/` repo provisioning.
INFISICAL_TOKEN=

# The Infisical project ID the token points at (Project → Settings → Project ID).
INFISICAL_PROJECT_ID=

# Environment slug to read/deploy against. REQUIRED at fetch time (no default).
INFISICAL_ENV=dev

# Optional — only set if you use a self-hosted Infisical instance.
# Defaults to https://app.infisical.com when unset.
# INFISICAL_HOST=https://app.infisical.com
