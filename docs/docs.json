{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "gtm-sdk",
  "description": "Go-To-Market Python SDK + CLI for account research, enrichment, CRM sync, and outreach. A foundation to bootstrap GTM Agents.",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting started",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Telemetry",
        "pages": [
          "telemetry/dash0-setup",
          "telemetry/grafana-setup"
        ]
      },
      {
        "group": "Changelog",
        "pages": [
          "changelog/2026-07-13"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://elvis.ai"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/elviskahoro/gtm-sdk"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/elviskahoro/gtm-sdk",
      "linkedin": "https://linkedin.com/in/elviskahoro",
      "website": "https://elvis.ai"
    }
  },
  "fonts": {
    "family": "Roboto"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system",
    "latex": true
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": true
  },
  "markdown": {
    "schema": true
  },
  "api": {
    "examples": {
      "autogenerate": true
    }
  }
