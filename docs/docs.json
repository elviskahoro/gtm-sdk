{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "gtm-sdk",
  "description": "Go-To-Market Python SDK + CLI for account research, enrichment, CRM sync, and outreach. A foundation to bootstrap GTM Agents.",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "installation",
              "secrets",
              "ai-tools"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/cli-contract"
            ]
          },
          {
            "group": "Telemetry",
            "pages": [
              "telemetry/overview",
              "telemetry/dash0-setup",
              "telemetry/grafana-setup"
            ]
          },
          {
            "group": "Contributing",
            "pages": [
              "contributing/development"
            ]
          },
          {
            "group": "Changelog",
            "pages": [
              "changelog/2026-07-18",
              "changelog/2026-week-of-07-13",
              "changelog/2026-07-15",
              "changelog/2026-07-14-exa",
              "changelog/2026-07-14",
              "changelog/2026-07-13"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "cli/index"
            ]
          },
          {
            "group": "Commands",
            "pages": [
              "cli/accounts",
              "cli/apollo",
              "cli/attio",
              "cli/enrichment",
              "cli/exa",
              "cli/gmail",
              "cli/granola",
              "cli/parallel",
              "cli/sanity",
              "cli/webhook"
            ]
          }
        ]
      }
    ]
  },
  "errors": {
    "404": {
      "redirect": false
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://elvis.ai"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/elviskahoro/gtm-sdk"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "add-mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/elviskahoro/gtm-sdk",
      "linkedin": "https://linkedin.com/in/elviskahoro",
      "website": "https://elvis.ai"
    }
  },
  "fonts": {
    "family": "Roboto"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system",
    "latex": true
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": true
  },
  "markdown": {
    "schema": true
  },
  "api": {
    "examples": {
      "autogenerate": true
    }
  }
}
