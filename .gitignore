# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
# pytest report exported to the repo root by .github/workflows/ci/pytest_dagger.py
junit.xml
pytest_rc

# OS
.DS_Store
*.pyc
*.egg-info/

# No trailing slash so these match the symlinks Conductor worktrees create
# pointing into the parent ai/ repo, not just real directories.
.agents
.claude

# Project scratch
tmp/
data/
out/
worktrees/

# Bazel workspace symlinks (bazel-bin, bazel-out, bazel-testlogs, bazel-gtm_sdk)
# created at the repo root by `bazel build`/`test`. The local opt-in disk cache
# lives under tmp/ (already ignored above); MODULE.bazel.lock IS committed.
/bazel-*

# Kilo Agent Manager generated state — the setup-script/run-script under
# .kilo/ are committed; managed worktrees and UI state are not.
.kilo/worktrees/
.kilo/agent-manager.json

# Real webhook payloads — keep raw evt_*.json samples out of version control.
# Use redacted/synthetic fixtures (sample-*.json) for documentation instead.
api/samples/**/evt_*.json

# Local secret env files (e.g. Infisical token shims) — never commit.
.env
.env.*
!.env.example

# External tools
# Beads / Dolt files (added by bd init)
# .beads is a symlink to ../.beads so this repo shares the parent ai/ beads DB
.beads 
.dolt/
*.db
.beads-credential-key

# Braintrust
.bt/*
.tapes/*

# Webhook URL registry — generated locally from Modal + Hookdeck APIs.
# Contains personal Modal URLs and Hookdeck IDs that don't belong in OSS.
webhooks/registry.yaml

# Force-track the shared helper package under scripts/lib/. Some operators have
# a `lib/` rule in their global gitignore that would otherwise exclude this
# repo-internal package and silently break script imports (see roborev finding).
!scripts/lib/
!scripts/lib/**
# Re-exclude generated artifacts inside the force-tracked directory.
scripts/lib/__pycache__/
scripts/lib/**/*.pyc

# Beads / Dolt files (added by bd init)
.beads/proxieddb/

# Gas Town (added by gt)
.runtime/
.logs/
state.json
CLAUDE.md
CLAUDE.local.md
