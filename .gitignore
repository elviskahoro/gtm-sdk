# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# OS
.DS_Store
*.pyc
*.egg-info/
.agents
.claude
.context

# Project scratch
tmp/
data/
out/
worktrees/

# Real webhook payloads — keep raw evt_*.json samples out of version control.
# Use redacted/synthetic fixtures (sample-*.json) for documentation instead.
api/samples/**/evt_*.json

# Local secret env files (e.g. Infisical token shims) — never commit.
.env
.env.*
!.env.example

# External tools
# Beads / Dolt files (added by bd init)
# .beads is a symlink to ../.beads so this repo shares the parent ai/ beads DB
.beads 
.dolt/
*.db
.beads-credential-key

# Braintrust
.bt/*

# Webhook URL registry — generated locally from Modal + Hookdeck APIs.
# Contains personal Modal URLs and Hookdeck IDs that don't belong in OSS.
webhooks/registry.yaml
